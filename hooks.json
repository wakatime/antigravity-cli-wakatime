{
  "antigravity-cli-wakatime": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "./scripts/run --event=preInvocation",
        "timeout": 5
      }
    ],
    "PostToolUse": [
      {
        "matcher": "write_to_file|replace_file_content|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/run --event=postToolUse",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
